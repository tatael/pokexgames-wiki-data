{
	"name": "pokexgames-wiki-data",
	"private": true,
	"version": "0.1.0",
	"description": "Scrape, validate and publish normalized PokeXGames wiki JSON bundles.",
	"type": "module",
	"scripts": {
		"sync": "node scripts/sync-wiki.mjs",
		"validate": "node scripts/validate-bundle.mjs",
		"coverage": "node scripts/report-coverage.mjs",
		"review:checklist": "node scripts/generate-review-checklist.mjs",
		"review:shortlist": "node scripts/generate-review-shortlist.mjs",
		"build": "node scripts/sync-wiki.mjs",
		"ci": "npm run test",
		"test": "node --test scripts/test/*.test.mjs",
		"serve": "node scripts/serve.mjs"
	},
	"engines": {
		"node": ">=20"
	}
}